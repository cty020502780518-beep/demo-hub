# ============================================================
# dream-rag — 环境变量模板
# 复制为 .env 后填写真实值，该文件可安全提交到版本控制
# 启动时自动读取，适用于 IDE 运行 main 或 mvn spring-boot:run
# ============================================================

# --- 运行环境 ---
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai
SERVER_PORT=8081

# --- MySQL ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/dream_rag?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=__CHANGE_ME__

# --- Redis ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# --- Elasticsearch ---
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=__CHANGE_ME__

# --- Kafka ---
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# --- MinIO ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=__CHANGE_ME__
MINIO_SECRET_KEY=__CHANGE_ME__
MINIO_BUCKET_NAME=uploads

# --- DeepSeek LLM ---
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=replace_with_api_key

# --- Embedding 向量化 ---
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=replace_with_api_key
EMBEDDING_API_MODEL=text-embedding-v4

# --- JWT ---
JWT_SECRET_KEY=replace_with_base64_256bit_secret

# --- 管理员初始化（首次运行时设为 true）---
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=__CHANGE_ME__
ADMIN_BOOTSTRAP_PRIMARY_ORG=default

# --- 其他可选配置 ---
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_WEB=DEBUG

# --- Docker Compose 基础设施密码 ---
MYSQL_ROOT_PASSWORD=__CHANGE_ME__
REDIS_PASSWORD=__CHANGE_ME__
MINIO_ROOT_USER=__CHANGE_ME__
MINIO_ROOT_PASSWORD=__CHANGE_ME__
