FROM docker.m.daocloud.io/library/node:18-alpine AS builder
WORKDIR /app

# Copy frontend source
COPY console/frontend /app/console/frontend
WORKDIR /app/console/frontend

# Install dependencies and build
RUN npm config set registry https://registry.npmjs.org/ && \
    npm ci --legacy-peer-deps && \
    NODE_OPTIONS="--max-old-space-size=4096" npm run build-prod

# Runtime stage
FROM docker.m.daocloud.io/library/nginx:1.15-alpine

# Environment variables
ENV NGINX_PORT=1881

# Generate nginx.conf
RUN echo "user  nginx; \
worker_processes  8; \
error_log  /var/log/nginx/error.log error; \
pid        /var/run/nginx.pid; \
events { worker_connections  65535; } \
http { \
  include       /etc/nginx/mime.types; \
  default_type  application/octet-stream; \
  sendfile      on; \
  resolver 127.0.0.11 ipv6=off valid=30s; \
  keepalive_timeout 65; \
  gzip on; \
  gzip_http_version 1.0; \
  gzip_disable \"MSIE [1-6].\"; \
  gzip_types text/plain application/x-javascript text/css application/javascript text/javascript; \
  server { \
    listen ${NGINX_PORT}; \
    index index.html; \
    root /var/www; \
    access_log off; \
    location / { \
      try_files \$uri \$uri/ /index.html; \
      expires -1; \
    } \
    location /console-api/ { \
      set \$console_hub http://console-hub:8080; \
      rewrite ^/console-api/(.*)$ /\$1 break; \
      proxy_pass \$console_hub; \
      proxy_http_version 1.1; \
      proxy_set_header Connection \"\"; \
      proxy_set_header Host \$host; \
      proxy_set_header X-Real-IP \$remote_addr; \
      proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for; \
    } \
    location ~ .*\.(gif|jpg|jpeg|png|PNG|bmp|swf|asp|cfm|xml|py|pl|lasso|cfc|afp|txt|zip|log|ico|csv|json|xls|pdf|mp3|mp4|apk)$ { \
      expires 1y; access_log off; \
    } \
    location ~ .*\.(js|css)?$ { \
      expires 1y; access_log off; \
    } \
  } \
}" > /etc/nginx/nginx.conf

# Expose port
EXPOSE ${NGINX_PORT}

# Copy static assets
COPY --from=builder /app/console/frontend/dist /var/www

# Copy entrypoint script
COPY console/frontend/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENTRYPOINT ["/docker-entrypoint.sh"]
