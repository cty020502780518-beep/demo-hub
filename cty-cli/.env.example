# CTY-Cli API Keys
# Copy this file to .env and fill in your keys.

# DeepSeek (default provider)
DEEPSEEK_API_KEY=sk-xxx

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, etc.)
# OPENAI_API_KEY=sk-xxx

# Default settings
DEFAULT_PROVIDER=deepseek
DEFAULT_MODEL=deepseek-v4-pro
